{
  "name": "changelog-ai",
  "version": "0.1.0",
  "description": "CLI/Action de GitHub para generar changelogs automáticos a partir de commits y PRs",
  "main": "dist/index.js",
  "bin": {
    "changelog-ai": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "changelog",
    "release-notes",
    "github-action",
    "cli",
    "automation"
  ],
  "author": "Sebastian Zapata",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0"
  }
}
